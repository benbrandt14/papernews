# Copy this file to `.env` and fill in. Docker Compose reads .env
# automatically and never logs its contents.

# Required for the default Gemini backend. Create a key at Google AI Studio.
GEMINI_API_KEY=AIzaSy...

# LLM pipeline switch (selection/summarization/formatting). Off by default.
# PAPERNEWS_LLM_ENABLED=1

# Backend: "gemini" (default) or "local" (Ollama).
# PAPERNEWS_LLM_BACKEND=gemini
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_TIMEOUT=1800

# Scheduling — pick one:
# INGEST_INTERVAL_SECONDS=14400   # every N seconds (default 4h)
# INGEST_SCHEDULE=07:00,18:00     # cron-style fixed times (overrides the interval)
# INGEST_TIMEZONE=Europe/London   # IANA tz, used with INGEST_SCHEDULE (default UTC)

# Post-ingest delivery hook (e.g. push the new PDF to a Boox Note).
# Drop the script in ./data/hooks/ and point this at it:
# POST_INGEST_HOOK=/data/hooks/push-to-boox.sh
# POST_INGEST_HOOK_TIMEOUT=300
