# Copy this file to `.env` and fill in. Docker Compose reads .env
# automatically and never logs its contents.

# API key for the default DeepSeek provider (https://platform.deepseek.com).
DEEPSEEK_API_KEY=sk-...

# LLM pipeline switch (selection/summarization/formatting). Off by default.
# PAPERNEWS_LLM_ENABLED=1

# Provider preset. Run `papernews providers` to list them; verify the active
# one reaches its API with `papernews check-llm`. Switching is one line here.
# PAPERNEWS_LLM_PROVIDER=deepseek     # deepseek openrouter openai groq together fireworks local
# OPENROUTER_API_KEY=sk-or-...        # provider key env matches the preset
#
# Escape hatch — point at ANY OpenAI-compatible endpoint without a preset:
# PAPERNEWS_LLM_BASE_URL=https://api.example.com/v1
# PAPERNEWS_LLM_API_KEY=...
# PAPERNEWS_LLM_MODEL=some-model
#
# Transport knobs (optional):
# PAPERNEWS_LLM_TIMEOUT=120           # seconds per request
# PAPERNEWS_LLM_MAX_TOKENS=0          # 0 = let the provider decide

# Scheduling — pick one:
# INGEST_INTERVAL_SECONDS=14400   # every N seconds (default 4h)
# INGEST_SCHEDULE=07:00,18:00     # cron-style fixed times (overrides the interval)
# INGEST_TIMEZONE=Europe/London   # IANA tz, used with INGEST_SCHEDULE (default UTC)

# Post-ingest delivery hook (e.g. push the new PDF to a Boox Note).
# Drop the script in ./data/hooks/ and point this at it:
# POST_INGEST_HOOK=/data/hooks/push-to-boox.sh
# POST_INGEST_HOOK_TIMEOUT=300
