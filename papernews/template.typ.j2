#import "@preview/mitex:0.2.4": mi, mitex

#set document(title: "Papernews", author: "Papernews")
#set page(
  width: 203mm,
  height: 270mm,
  margin: (inside: 20mm, outside: 20mm, top: 24mm, bottom: 24mm),
  header: none,
  footer: none
)

#set text(
  font: "New Computer Modern",
  size: 11pt,
  lang: "en",
)

#set par(
  justify: true,
  first-line-indent: 1.1em,
  leading: 0.65em,
)
#set par(spacing: 0.65em)

// Magazine typography
#let sourcelabel(content) = text(size: 0.85em, tracking: 0.05em, smallcaps(content))

#let sectionhead(content) = text(size: 1.2em, weight: "bold", content)

#let articletitle(url, title) = {
  v(0.35em)
  text(size: 1.2em, weight: "bold", link(url, title))
  v(0.35em)
}

#let articlelede(content) = {
  v(0.35em)
  text(style: "italic", content)
  v(0.55em)
  line(length: 100%, stroke: 0.4pt)
  v(0.55em)
}

// --- Contents (also the cover) --------------------------------------------
#align(center)[
  #text(size: 36pt, weight: "bold", "Papernews") \
  #v(0.7em)
  #text(size: 11pt)[((( date | typst )))] #h(1em) #sym.dot.c #h(1em) ((( articles | length ))) article((* if articles|length != 1 *))s((* endif *))
]

((* if decorations.quote *))
#v(0.7em)
#pad(left: 1em)[
  #text(size: 9pt, style: "italic")[((( decorations.quote.text | typst )))] \
  #align(right)[
    #text(size: 9pt, smallcaps[--- ((* if decorations.quote.author *))((( decorations.quote.author | typst )))((* else *))Anonymous((* endif *))])
    #text(size: 7pt, style: "italic")[(Wikiquote QOTD)]
  ]
]
((* endif *))

((* if decorations.world_news *))
#v(0.6em)
#line(length: 100%, stroke: 0.4pt)
#v(0.6em)
#grid(
  columns: (1fr, auto),
  [#sectionhead("World news")],
  [#text(size: 9pt, style: "italic", "((( decorations.world_news_date | typst )))")]
)
#v(0.4em)

#set par(spacing: 0.4em)
#set text(size: 9pt)
#set par(first-line-indent: 0pt)
#columns(2)[
((* set wn_len = decorations.world_news | length *))
((* set wn_break = (wn_len // 2) + (wn_len % 2) + 1 *))
((* for item in decorations.world_news *))
  ((* if loop.index == wn_break *))
  #colbreak()
  ((* endif *))
  #box(width: 100%)[
    ((* if item.url *))#link("((( item.url | typst_url )))")[((( item.text | typst )))]((* else *))((( item.text | typst )))((* endif *))
    ((* if item.source *))#text(size: 7pt, style: "italic")[\ (((( item.source | typst ))))]((* endif *))
  ]
  #v(0.35em)
((* endfor *))
]
((* endif *))

#v(0.6em)
#line(length: 100%, stroke: 0.4pt)
#v(0.8em)

#set par(spacing: 0.6em)
#set text(size: 9pt)
#set par(first-line-indent: 0pt, leading: 0.7em)
#columns(2)[
((* set art_len = articles | length *))
((* set art_break = (art_len // 2) + (art_len % 2) + 1 *))
((* set ns = namespace(prev='') *))
((* for art in articles *))
  ((* if loop.index == art_break *))
  #colbreak()
  ((* endif *))
  ((* if art.source != ns.prev *))
    #v(1em, weak: true)
    #sectionhead("((( art.source | typst )))")
    #v(0.45em, weak: true)
    ((* set ns.prev = art.source *))
  ((* endif *))
  #link(<art((( loop.index )))>)[((( art.title | typst )))]((* if art.date *)) #box(width: 1fr, repeat[ . ]) #text(size: 7pt, style: "italic")["((( art.date | typst )))"]((* endif *)) \
((* endfor *))
]

((* if decorations.dyk *))
#v(1.5em)
#line(length: 100%, stroke: 0.4pt)
#v(0.6em)
#sectionhead("Did you know...")
#v(0.4em)

#set text(size: 9pt)
#set par(first-line-indent: 0pt)
#set par(spacing: 0.4em)
((* for fact in decorations.dyk *))
  #sym.dots ((( fact | typst ))) \
((* endfor *))
((* endif *))

#pagebreak()

// --- Front matter: headlines + ledes --------------------------------------
#set page(
  footer: align(center)[#context counter(page).display()]
)
#counter(page).update(1)

#text(size: 14pt, weight: "bold", "In this issue")
#v(0.6em)
#line(length: 100%, stroke: 0.4pt)
#v(0.8em)

#set par(first-line-indent: 0pt)
((* for art in articles *))
  #sourcelabel("((( art.source | typst )))")((* if art.date *)) #sym.dot.c #text(size: 9pt, style: "italic")["((( art.date | typst )))"]((* endif *)) #h(1fr) #text(size: 9pt)[p. #context locate(<art((( loop.index )))>).page()] \
  #v(0.15em)
  #link(<art((( loop.index )))>)[*((( art.title | typst )))*] \
  #v(0.15em)
  #text(size: 9pt, style: "italic")["((( art.summary | typst )))"]
  #v(0.9em)
((* endfor *))

#pagebreak()

// --- Articles -------------------------------------------------------------
#set par(first-line-indent: 1.1em, leading: 0.65em)
#set par(spacing: 0.65em)
#show figure.caption: it => text(size: 8pt, style: "italic", it.body)
((* for art in articles *))
  [#<art((( loop.index )))>]
  #sourcelabel("((( art.source | typst )))")((* if art.date *)) #sym.dot.c #text(size: 9pt, style: "italic")["((( art.date | typst )))"]((* endif *))
  #articletitle("((( art.url | typst_url )))", "((( art.title | typst )))")
  #articlelede("((( art.summary | typst )))")

  ((* if art.text | length > 2000 *))
    #columns(2)[
      ((( art.text | typst_body )))
    ]
  ((* else *))
    ((( art.text | typst_body )))
  ((* endif *))

  #pagebreak()
((* endfor *))