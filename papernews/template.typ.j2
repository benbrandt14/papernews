#import "@preview/mitex:0.2.4": mi, mitex

#set document(title: "Papernews", author: "Papernews")
#set page(
  width: 203mm,
  height: 270mm,
  margin: (inside: 20mm, outside: 20mm, top: 20mm, bottom: 20mm),
  header: none,
  footer: none
)

#set text(
  font: ("New Computer Modern", "Linux Libertine", "Times New Roman"),
  size: 10pt,
  lang: "en",
)

#set par(
  justify: true,
  first-line-indent: 1em,
  leading: 0.6em,
  spacing: 0.6em
)

// Salience weighting (structured-IR bodies): high-salience sentences get
// a heavier weight, boilerplate fades toward grey. E-Ink safe: never
// lighter than 40% luma.
#let smart-sentence(weight: 1.0, body) = {
  if weight >= 0.75 { text(weight: "semibold", body) }
  else if weight <= 0.25 { text(fill: luma(40%), body) }
  else { body }
}

// Magazine typography
#let sourcelabel(content) = text(size: 0.85em, tracking: 0.05em, smallcaps(content))

#let sectionhead(content) = {
  v(0.5em)
  text(size: 1.2em, weight: "bold", font: "New Computer Modern", content)
  v(0.2em)
  line(length: 100%, stroke: 0.5pt)
  v(0.4em)
}

#let articletitle(url, title) = {
  v(0.35em)
  text(size: 1.3em, weight: "bold", link(url, title))
  v(0.35em)
}

#let articlelede(content) = {
  v(0.35em)
  text(style: "italic", size: 10pt, content)
  v(0.55em)
  line(length: 100%, stroke: 0.4pt)
  v(0.55em)
}

// --- Cover Page --------------------------------------------
#align(center)[
  #text(size: 50pt, weight: "bold", font: "New Computer Modern")[Papernews] \
  #v(0.4em)
  #line(length: 100%, stroke: 1.5pt)
  #v(0.3em)
  #text(size: 10pt, tracking: 0.15em, smallcaps[((( decorations.generation_time | typst ))) #h(1fr) ((( articles | length ))) Articles #h(1fr) ((( decorations.total_tokens ))) Tokens / ((( decorations.total_cost )))¢])
  #v(0.3em)
  #line(length: 100%, stroke: 1.5pt)
]
#v(1.5em)

#columns(3, gutter: 1.5em)[

  ((* if decorations.quote *))
  #text(size: 10.5pt, style: "italic")[ ((( decorations.quote.text | typst ))) ] \
  #align(right)[
    #text(size: 9pt, smallcaps[--- ((* if decorations.quote.author *))((( decorations.quote.author | typst )))((* else *))Anonymous((* endif *))])
  ]
  #v(1em)
  ((* endif *))

  ((* if decorations.world_news *))
  #sectionhead("World News")
  ((* for item in decorations.world_news *))
    #block(breakable: false)[
      #set par(first-line-indent: 0pt, justify: false)
      *((( item | typst )))*
    ]
    #v(0.8em)
  ((* endfor *))
  ((* endif *))

  ((* if decorations.dyk *))
  #sectionhead("Did you know...")
  #set par(first-line-indent: 0pt, justify: false)
  ((* for fact in decorations.dyk *))
    #block(breakable: true)[
      #sym.dots ((( fact | typst )))
    ]
    #v(0.6em)
  ((* endfor *))
  ((* endif *))

  #sectionhead("Index")
  #set par(first-line-indent: 0pt, justify: false)
  ((* set ns = namespace(prev='') *))
  ((* for art in articles *))
    ((* if art.category != ns.prev *))
      #v(0.8em, weak: true)
      #text(size: 8.5pt, weight: "bold", fill: luma(50%), smallcaps([((( art.category | typst )))]))
      #v(0.2em, weak: true)
      ((* set ns.prev = art.category *))
    ((* endif *))
    #block(breakable: true)[
      #link(<art((( loop.index )))>)[#text(size: 9.5pt)[((( art.title | typst )))]]
    ]
    #v(0.4em)
  ((* endfor *))

] 

#pagebreak()

// --- Front matter: headlines + ledes --------------------------------------
#set page(
  footer: align(center)[#context counter(page).display()],
  margin: (inside: 20mm, outside: 20mm, top: 24mm, bottom: 24mm)
)
#counter(page).update(1)

#text(size: 16pt, weight: "bold", font: "New Computer Modern", "In this issue")
#v(0.6em)
#line(length: 100%, stroke: 1pt)
#v(1em)

#columns(2, gutter: 2em)[
  #set par(first-line-indent: 0pt)
  ((* set ns = namespace(prev='') *))
  ((* for art in articles *))
    ((* if art.category != ns.prev *))
      #v(0.8em, weak: true)
      #text(size: 11pt, weight: "bold", font: "New Computer Modern", [((( art.category | typst )))])
      #v(0.4em, weak: true)
      ((* set ns.prev = art.category *))
    ((* endif *))
    #block(breakable: true)[
      #sourcelabel([((( art.source | typst )))])((* if art.date *)) #sym.dot.c #text(size: 9pt, style: "italic")[[((( art.date | typst )))]]((* endif *)) #h(1fr) #text(size: 9pt, weight: "bold")[p. #context locate(<art((( loop.index )))>).page()] \
      #v(0.2em)
      #link(<art((( loop.index )))>)[*((( art.title | typst )))*] \
      #v(0.3em)
      #text(size: 9.5pt, style: "italic")[[((( art.summary | typst )))]]
      #v(1em)
    ]
  ((* endfor *))
]

#pagebreak()

// --- Articles -------------------------------------------------------------
#set par(first-line-indent: 1.2em, leading: 0.65em)
#set par(spacing: 0.65em)
#show figure.caption: it => text(size: 8pt, style: "italic", it.body)

((* set ns = namespace(prev_cat='') *))
((* for art in articles *))
  
  ((* if art.category != ns.prev_cat *))
    #pagebreak(weak: true)
    #align(center)[
      #v(2em)
      #text(size: 24pt, weight: "bold", font: "New Computer Modern")[((( art.category | typst )))]
      #v(0.5em)
      #line(length: 100%, stroke: 1.5pt)
      #v(2em)
    ]
    ((* set ns.prev_cat = art.category *))
  ((* else *))
    #v(2.5em)
    #align(center)[#line(length: 30%, stroke: 0.5pt)]
    #v(2.5em)
  ((* endif *))

  // Print the Source inside the body, since the Category is now the major section header
  #sourcelabel([((( art.category | typst )))]) #sym.dot.c #text(size: 9pt, weight: "bold", fill: luma(30%))[((( art.source | typst )))]((* if art.date *)) #sym.dot.c #text(size: 9pt, style: "italic")[((( art.date | typst )))]((* endif *)) #h(1fr) #text(size: 8pt, fill: luma(50%))[((( art.telemetry.formatted_tokens ))) tokens / ((( art.telemetry.formatted_cost )))¢]
  #articletitle("((( art.url | typst_url )))", [((( art.title | typst )))]) <art((( loop.index )))>
  #articlelede([((( art.summary | typst )))])

  ((* if art.body_markdown | length > 2000 *))
    #columns(2, gutter: 1.5em)[
      ((* if art.body_typst *))
      ((( art.body_typst )))
      ((* else *))
      ((( art.body_markdown | typst_body )))
      ((* endif *))
    ]
  ((* else *))
    ((* if art.body_typst *))
    ((( art.body_typst )))
    ((* else *))
    ((( art.body_markdown | typst_body )))
    ((* endif *))
  ((* endif *))

  // Force long articles to break to a new page so the next article starts fresh
  ((* if art.body_markdown | length > 3000 *))
    #pagebreak(weak: true)
  ((* endif *))
((* endfor *))