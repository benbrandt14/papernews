#set document(title: "Papernews", author: "Papernews")
#set page(
  width: 203mm,
  height: 270mm,
  margin: (inside: 20mm, outside: 20mm, top: 24mm, bottom: 24mm),
  header: none,
  footer: none
)

#set text(font: "Linux Libertine", size: 11pt, lang: "en")
#set par(justify: true, first-line-indent: 1.1em, leading: 0.65em, spacing: 0.65em)

// --- Universal Layout Macros ---
#let sourcelabel(content) = text(size: 0.85em, tracking: 0.05em, smallcaps(content))
#let sectionhead(content) = text(size: 1.2em, weight: "bold", content)

#let articletitle(url, title) = {
  v(0.35em)
  text(size: 1.2em, weight: "bold", link(url, title))
  v(0.35em)
}

#let articlelede(content) = {
  v(0.35em)
  text(style: "italic", content)
  v(0.55em)
  line(length: 100%, stroke: 0.4pt)
  v(0.55em)
}

#let generic_article_block(source, url, title, summary, body_text) = {
  block(breakable: false)[
    #if source != "" [#sourcelabel([#source])]
    #if title != "" [#articletitle(url, [#title])]
    #if summary != "" [#articlelede([#summary])]
  ]
  [#body_text]
  v(2.5em)
}

// ==========================================
// THE COVER PAGE
// ==========================================
#align(center)[
  #text(size: 36pt, weight: "bold", "Papernews") \
  #v(0.7em)
  #text(size: 11pt)[((( date | typst )))]
]
#v(1em)
#line(length: 100%, stroke: 0.4pt)
#v(1em)

#columns(2)[
  // Left Column: The Index
  #sectionhead("Index")
  #v(0.8em)
  ((* for category, items in regions.index.items() *))
    #text(weight: "bold")[((( category )))] \
    ((* for item in items *))
      #link("((( item.url | typst_url )))")[((( item.title | typst )))] \
      #v(0.3em)
    ((* endfor *))
    #v(0.8em)
  ((* endfor *))
  
  #colbreak()
  
  // Right Column: Sidebars (Quotes, News Briefs)
  ((* for item in regions.sidebar *))
    #generic_article_block(
      "((( item.source )))", 
      "((( item.url | typst_url )))", 
      "((( item.title | typst )))", 
      "((( item.summary | typst )))", 
      [((( item.body_markdown | typst_body )))]
    )
  ((* endfor *))
]

// ==========================================
// THE INTERIOR PAGES
// ==========================================
#pagebreak()
#set page(footer: align(center)[#context counter(page).display()])
#counter(page).update(1)

((* for category, items in regions.interior.items() *))
  #align(center)[
    #text(size: 18pt, weight: "bold")[((( category )))]
    #v(0.5em)
    #line(length: 40%, stroke: 1.5pt)
    #v(1.5em)
  ]

  #columns(2, gutter: 2em)[
    ((* for item in items *))
      #generic_article_block(
        "((( item.source )))", 
        "((( item.url | typst_url )))", 
        "((( item.title | typst )))", 
        "((( item.summary | typst )))", 
        [((( item.body_markdown | typst_body )))]
      )
    ((* endfor *))
  ]
  #pagebreak(weak: true)
((* endfor *))