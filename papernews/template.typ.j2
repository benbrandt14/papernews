#set document(title: "Papernews", author: "Papernews Generator")
#set page(
  width: 203mm,
  height: 270mm,
  margin: (inside: 20mm, outside: 20mm, top: 24mm, bottom: 24mm),
  header: none,
  footer: none
)
#set text(
  font: "Linux Libertine",
  size: 11pt,
  lang: "en",
)
#set par(
  justify: true,
  first-line-indent: 1.1em,
  leading: 0.65em,
  spacing: 0.65em
)
#show par: set block(spacing: 0.65em) 

// --- Helper Functions ---
#let sourcelabel(content) = text(size: 0.85em, tracking: 0.05em, smallcaps(content))

#let sectionhead(content) = {
  v(1em)
  text(size: 1.2em, weight: "bold", content)
  v(0.3em)
  line(length: 100%, stroke: 1pt)
  v(0.5em)
}

#let articletitle(url, title) = {
  v(0.35em)
  text(size: 1.2em, weight: "bold", link(url, title))
  v(0.35em)
}

#let articlelede(content) = {
  v(0.35em)
  text(style: "italic", content)
  v(0.55em)
  line(length: 100%, stroke: 0.4pt)
  v(1em)
}

// ==========================================
// THE COVER PAGE
// ==========================================
#align(center)[
  #text(size: 48pt, weight: "bold")[Papernews] \
  #v(1em)
  #text(size: 14pt, style: "italic")[((( run_time )))]
]
#v(2em)

// Rigid 3-Column Masonry
#columns(3, gutter: 2em)[
  
  // 1. The Index
  #sectionhead("Index")
  (((* for category, arts in articles_by_category.items() *)))
    #text(weight: "bold")[((( category )))] \
    (((* for art in arts *)))
      #link("((( art.url )))")[((( art.title )))] \
      #v(0.4em)
    (((* endfor *)))
    #v(1em)
  (((* endfor *)))

  #colbreak()

  // 2. Quote of the Day
  (((* if quote *)))
    #sectionhead("Quote of the Day")
    #text(style: "italic")[((( quote.body_markdown )))]
    #v(1.5em)
  (((* endif *)))

  // 3. Current Events
  (((* if wiki_events *)))
    #sectionhead("Current Events")
    (((* for event in wiki_events *)))
      #text(weight: "bold")[((( event.title )))] \
      ((( event.body_markdown )))
      #v(1em)
    (((* endfor *)))
  (((* endif *)))
]

// ==========================================
// INTERIOR ARTICLES
// ==========================================
#pagebreak()
#set page(header: align(right)[#text(size: 9pt, smallcaps[Papernews Daily - ((( run_time )))])])

(((* for category, arts in articles_by_category.items() *)))
  #align(center)[
    #text(size: 20pt, weight: "bold")[((( category )))]
    #v(0.5em)
    #line(length: 100%, stroke: 1.5pt)
    #v(1.5em)
  ]

  #columns(2, gutter: 2em)[
    (((* for art in arts *)))
      #block(breakable: false)[
        #sourcelabel([((( art.source )))])
        #articletitle("((( art.url )))", [((( art.title )))])
        #articlelede([((( art.summary )))])
      ]
      ((( art.body_markdown )))
      #v(2.5em)
    (((* endfor *)))
  ]
  #pagebreak(weak: true)
(((* endfor *)))