#set document(title: "Papernews Daily")
#set page(width: 11in, height: 15in, margin: 0.8in)
#set text(font: "Linux Libertine", size: 9pt)
#set par(justify: true, first-line-indent: 1.2em, leading: 0.7em, spacing: 0pt)

// --- Helper Functions ---
#let headline(size: 18pt, content) = {
  set text(size: size, weight: "bold", font: "Linux Libertine")
  set par(justify: false, leading: 0.9em, first-line-indent: 0pt)
  v(0.6em)
  content
  v(0.6em)
}

#align(center)[
  #text(font: ("Old English Text MT", "Chomsky"), size: 68pt)[The Papernews] \
  #v(0.2em)
  #line(length: 100%, stroke: 2pt)
  #v(1.5pt)
  #line(length: 100%, stroke: 0.5pt)
  #v(0.4em)
  #text(size: 9pt, smallcaps[((( run_time )))])
  #v(0.4em)
  #line(length: 100%, stroke: 0.5pt)
  #v(1.5pt)
  #line(length: 100%, stroke: 2pt)
]
#v(1.5em)

// --- Front Page Grid ---
#grid(
  columns: (1fr, 2fr, 1fr),
  gutter: 1.8em,
  
  // Left Sidebar
  [
    #set par(first-line-indent: 0pt)
    #align(center)[#text(size: 10pt, weight: "bold", smallcaps["News Summary"])]
    #line(length: 100%, stroke: 0.5pt)
    
    (((* for chunk in sidebars *)))
      #headline(size: 11pt)[((( chunk.headline )))]
      #text(size: 8.5pt)[((( chunk.body_markdown )))]
      #v(1em)
    (((* endfor *)))
  ],
  
  // Center: The Hero Story
  [
    (((* if hero *)))
      #headline(size: 24pt)[((( hero.headline )))]
      ((( hero.body_markdown )))
    (((* endif *)))
  ],
  
  // Right Sidebar: Academic Digests
  [
    #set par(first-line-indent: 0pt)
    #align(center)[#text(size: 10pt, weight: "bold", smallcaps["Academic Radar"])]
    #line(length: 100%, stroke: 0.5pt)
    
    (((* for chunk in academics *)))
      #headline(size: 11pt)[((( chunk.headline )))]
      #text(size: 8pt)[((( chunk.body_markdown )))]
      #v(1em)
    (((* endfor *)))
  ]
)

#pagebreak()
// --- Standard Articles ---
#columns(2, gutter: 2em)[
  (((* for chunk in standards *)))
    #headline(size: 16pt)[((( chunk.headline )))]
    ((( chunk.body_markdown )))
    #v(2em)
  (((* endfor *)))
]