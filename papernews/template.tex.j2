% --- Magazine typography ----------------------------------------------------
% Classic paragraph treatment: first-line indent, no vertical parskip ladder.
\setlength{\parindent}{1.1em}
\setlength{\parskip}{0pt}
\setlength{\columnsep}{7mm}
\setlength{\columnseprule}{0pt}
\linespread{1.06}

% Small-caps source label with light letter-spacing.
% Letter-spacing via fontspec (xetex-native; microtype's \textls is fragile
% on Debian's TeX Live).
\newcommand{\sourcelabel}[1]{{\small\scshape\addfontfeature{LetterSpace=10}#1}}

% Section heading used for source-blocks in the contents listing and for
% the World-news / DYK blocks on the cover. Larger and bold so it pops
% against the \small entry text below.
\newcommand{\sectionhead}[1]{{\large\bfseries #1}}

% Headline: paragraph-sized bold serif (not banner).
\newcommand{\articletitle}[2]{%
  \par\noindent
  {\large\bfseries\raggedright\href{#1}{#2}\par}%
}

% Lede: body-sized italic, justified, sitting under the title.
\newcommand{\articlelede}[1]{%
  \par\vspace{0.35em}\noindent
  {\itshape #1\par}%
  \vspace{0.55em}%
  \noindent\rule{\linewidth}{0.4pt}%
  \par\vspace{0.55em}%
}

\pagestyle{plain}

\begin{document}

% --- Contents (also the cover) --------------------------------------------
\thispagestyle{empty}
\begin{center}
{\fontsize{28}{32}\selectfont\bfseries Papernews}\par
\vspace{0.7em}
{\normalsize ((( date | tex )))\quad\textperiodcentered\quad ((( articles | length ))) article((* if articles|length != 1 *))s((* endif *))}\par
\end{center}
((* if decorations.quote *))
\vspace{0.7em}
\begin{quote}\small
\itshape ``((( decorations.quote.text | tex )))''
\par\vspace{0.2em}\hfill{\upshape\scshape\textemdash\ ((* if decorations.quote.author *))((( decorations.quote.author | tex )))((* else *))Anonymous((* endif *))}\,{\upshape\tiny\itshape (Wikiquote QOTD)}
\end{quote}
((* endif *))

