\setlength{\parskip}{0.4em}
\linespread{1.1}

\newcommand{\tocsection}[1]{%
  \par\addvspace{1em}%
  % NB: deliberately no \needspace here. Inside multicols, \needspace acts on
  % page-remaining space rather than column-remaining space, so on a dense
  % cover it triggers a full page break even when the *next column* has plenty
  % of room — leaving col 2 of the cover empty and orphaning the next source
  % to its own page. \nobreak below keeps the heading attached to its first
  % entry, which is the actual concern (orphan section heads).
  \sectionhead{#1}\par
  \nobreak\vspace{0.45em}\nobreak
}

% Entry: aligned flush with the section heading.
% #1 anchor, #2 title, #3 trailing suffix (e.g. "\,\dotfill\,date" or empty)
\newcommand{\tocentry}[3]{%
  \noindent\hyperlink{#1}{#2}#3\par
}

\begin{multicols}{2}
((* set ns = namespace(prev='') *))
((* for art in articles *))
((* if art.source != ns.prev *))
\tocsection{((( art.source | tex )))}
((* set ns.prev = art.source *))
((* endif *))
\tocentry{art((( loop.index )))}{((( art.title | tex )))}{((* if art.date *))\,\dotfill\,\mbox{{\scriptsize\itshape ((( art.date | tex )))}}((* endif *))}
((* endfor *))
\end{multicols}
\endgroup

((* if decorations.dyk *))
\par\addvspace{1.5em}
\noindent\rule{\linewidth}{0.4pt}\par
\vspace{0.6em}
\noindent\sectionhead{Did you know\dots}\par
\vspace{0.4em}
\begingroup
\small
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.3em}
((* for fact in decorations.dyk *))
\noindent\textellipsis\ ((( fact | tex )))\par
((* endfor *))
\endgroup
((* endif *))
